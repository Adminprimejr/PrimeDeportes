# Email delivery — sign up free at resend.com (3,000 emails/month free)
RESEND_API_KEY=re_your_api_key_here

# Verified sender email (requires domain verification in Resend dashboard)
# For testing, use: onboarding@resend.dev
RESEND_FROM_EMAIL=noreply@primedeportes.com
RESEND_TO_EMAIL=journalist@primedeportes.com

# Calendly scheduling link (create account at calendly.com)
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/primedeportes/15min

# Public site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://primedeportes.com

# Admin panel password — set a strong password, never commit the real value
ADMIN_SECRET=change-me-to-a-strong-password

# Anthropic API key for AI article generation (get at console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-your-api-key-here
